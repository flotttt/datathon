# Copie ce fichier en .env puis renseigne ta cle (le .env n'est pas versionne).
#   cp .env.example .env
# Fournisseur LLM compatible OpenAI (defaut: DeepSeek V4 Flash).
LLM_API_KEY=ta_cle_ici

