{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "synthese_globale": {
      "type": "string",
      "description": "Deux a trois phrases neutres resumant la dynamique de la crise."
    },
    "recommandations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "narratif": {
            "type": "string",
            "description": "Le narratif vise (ex: copinage, censure, cyberharcelement)."
          },
          "poids": {
            "type": "string",
            "description": "Poids du narratif dans la crise (ex: 42%)."
          },
          "priorite": {
            "type": "string",
            "enum": ["haute", "moyenne", "basse"]
          },
          "decision": {
            "type": "string",
            "enum": ["repondre", "surveiller", "ne_pas_alimenter"]
          },
          "angle": {
            "type": "string",
            "description": "L'angle de riposte recommande, factuel et defensif."
          },
          "messages_cles": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Points cles a transmettre, pas le texte final."
          },
          "audience": {
            "type": "string",
            "description": "Public vise par la reponse."
          },
          "a_eviter": {
            "type": "string",
            "description": "Ce qu'il ne faut pas faire sur ce narratif."
          },
          "justification": {
            "type": "string",
            "description": "Pourquoi cette decision, en une phrase."
          }
        },
        "required": [
          "narratif",
          "poids",
          "priorite",
          "decision",
          "angle",
          "messages_cles",
          "audience",
          "a_eviter",
          "justification"
        ]
      }
    }
  },
  "required": ["synthese_globale", "recommandations"]
}
